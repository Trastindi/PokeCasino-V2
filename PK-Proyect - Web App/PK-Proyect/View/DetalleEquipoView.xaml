<Window x:Class="PK_Proyect.View.DetalleEquipoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle del Equipo"
        Height="560" Width="480"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue"   Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed"    Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox"    Color="#FFF5F2DF"/>
    </Window.Resources>

    <Border CornerRadius="18" BorderThickness="3" BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/PokeYellow2.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="15" BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Barra superior ── -->
                <Border Grid.Row="0" Background="{StaticResource PkYellow}"
                        CornerRadius="15,15,0,0">
                    <Grid>
                        <TextBlock Text="{Binding Equipo.Nombre, StringFormat='Equipo: {0}'}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="15" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource PkBlue}"/>
                        <Button Content="X"
                                FontFamily="{StaticResource PokemonClassic}"
                                FontSize="18"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                HorizontalAlignment="Right" Margin="0,4,8,4"
                                Click="btnClose_Click"/>
                    </Grid>
                </Border>

                <!-- ── Lista de integrantes ── -->
                <ScrollViewer Grid.Row="1" Margin="8,8,8,10"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Integrantes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Black" BorderThickness="2"
                    Margin="4,4,4,0" Padding="8"
                    Background="#E0D0A8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Sprite usando SpriteUrl del wrapper -->
                                        <Image Source="{Binding SpriteUrl}"
                           Width="64" Height="64"
                           Margin="0,0,12,0"/>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="Black"/>
                                            <TextBlock Text="{Binding Nivel, StringFormat='Nivel: {0}'}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="12" Foreground="#333"/>
                                            <TextBlock Text="{Binding TipoPrincipal, StringFormat='Tipo: {0}'}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="12" Foreground="#555"/>
                                        </StackPanel>

                                        <!-- Botón eliminar (X rojo) -->
                                        <Button Grid.Column="2"
                            Content="X"
                            Width="28" Height="28"
                            FontFamily="{StaticResource PokemonClassic}"
                            FontSize="14"
                            Foreground="{StaticResource PkWhite}"
                            Background="{StaticResource PkRed}"
                            BorderBrush="{StaticResource PkBlue}"
                            BorderThickness="2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding DataContext.RemovePokemonCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <!-- Empty state -->
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Integrantes.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <TextBlock Text="Este equipo no tiene integrantes aún."
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="12" Foreground="#888"
                                           HorizontalAlignment="Center"
                                           Margin="0,40,0,0"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>
    </Border>
</Window>
