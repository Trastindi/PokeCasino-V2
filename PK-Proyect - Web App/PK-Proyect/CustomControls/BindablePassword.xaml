<UserControl x:Class="PK_Proyect.CustomControls.BindablePassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PK_Proyect.CustomControls"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>

        <Grid.Resources>

            <!-- Paleta Game Boy -->
            <SolidColorBrush x:Key="GbDark" Color="#2E4F32"/>
            <SolidColorBrush x:Key="GbMid" Color="#4A7A42"/>
            <SolidColorBrush x:Key="GbLight" Color="#A7D37C"/>
            <SolidColorBrush x:Key="GbVeryLight" Color="#E8F5C8"/>

            <!-- Texto retro -->
            <Style x:Key="RetroText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="Foreground" Value="{StaticResource GbDark}"/>
                <Setter Property="FontSize" Value="20"/>
            </Style>

            <!-- Cajas retro -->
            <Style x:Key="RetroBox" TargetType="PasswordBox">
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Background" Value="{StaticResource GbLight}"/>
                <Setter Property="BorderBrush" Value="{StaticResource GbDark}"/>
                <Setter Property="BorderThickness" Value="3"/>
                <Setter Property="Padding" Value="5"/>
            </Style>

            <!-- Botón estilo Game Boy -->
            <Style x:Key="RetroButton" TargetType="Button">
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="Background" Value="{StaticResource GbMid}"/>
                <Setter Property="Foreground" Value="{StaticResource GbVeryLight}"/>
                <Setter Property="BorderBrush" Value="{StaticResource GbDark}"/>
                <Setter Property="BorderThickness" Value="4"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

        </Grid.Resources>

        <PasswordBox x:Name="txtPassword"
                     Style="{StaticResource RetroBox}"
                     Width="448"/>

    </Grid>

</UserControl>
