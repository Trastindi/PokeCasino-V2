<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="PK_Proyect.View.PerfilUserView"
        Title="Perfil del Jugador"
        Width="700" Height="600"
        Icon="/Images/logo.ico"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        Background="Transparent"
        ResizeMode="NoResize"
        AllowsTransparency="True">


    <Border CornerRadius="18"
        BorderThickness="3"
        BorderBrush="#FFD700">
        
        <Border.Background>
            <ImageBrush ImageSource="/Images/perfil.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border BorderBrush="#FFD700" BorderThickness="4" CornerRadius="15" Margin="20">

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- TÍTULO RETRO -->
                <TextBlock Text="PERFIL DEL JUGADOR"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FFD700"
                       FontFamily="{StaticResource PokemonClassic}"
                       />

                <!-- PANEL PRINCIPAL -->
                <Grid Margin="0,68,0,0" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- COLUMNA IZQUIERDA -->
                    <StackPanel Grid.Column="0" Margin="20" VerticalAlignment="Top">

                        <TextBlock Text="ID:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding Id}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Opacity="0.7"
                               Background="#1A1A1A"
                               Margin="0,0,0,20"/>

                        <TextBlock Text="Nombre:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                              FontSize="16"/>
                        <TextBlock Text="{Binding Nombre}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Margin="0,0,0,20"
                               Opacity="0.7"
                               Background="#1A1A1A"/>

                        <TextBlock Text="Apellido:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding Apellido}"
                               Foreground="White"
                               Background="Black"
                               Opacity="0.7"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Margin="0,0,0,20"/>

                        <TextBlock Text="Año de nacimiento:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding Birthdate}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Background="Black"
                               Opacity="0.7"
                               Margin="0,0,0,20"/>

                    </StackPanel>

                    <!-- COLUMNA DERECHA -->
                    <StackPanel Grid.Column="1" Margin="20" VerticalAlignment="Top">

                        <TextBlock Text="Nombre de usuario:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding Username}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Margin="0,0,0,20"
                               Opacity="0.7"
                               Background="#1A1A1A"/>

                        <TextBlock Text="Correo:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding Correo}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Background="Black"
                               Opacity="0.7"
                               Margin="0,0,0,20"/>

                        <TextBlock Text="Pokés:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding Pokes}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Background="Black"
                               Opacity="0.7"    
                               Margin="0,0,0,20"/>

                        <TextBlock Text="Fichas de casino:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                        <TextBlock Text="{Binding FichasCasino}"
                               Foreground="White"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"
                               Background="Black"
                               Opacity="0.7"
                               Margin="0,0,0,20"/>

                    </StackPanel>
                </Grid>

                <!-- BOTÓN CERRAR -->
                <Button Grid.Row="2"
                    Content="CERRAR"
                    Width="150"
                    HorizontalAlignment="Left"
                    Background="#FFD700"
                    Foreground="Black"
                    FontFamily="{StaticResource PokemonClassic}"
                    FontWeight="Bold"
                    FontSize="14"
                    Click="BtnCerrar_Click" Margin="412,15,0,16"/>
                <Button Grid.Row="2"
                    Content="Reset Password"
                    Width="188"
                    HorizontalAlignment="Left"
                    Background="#FFD700"
                    Foreground="Black"
                    FontFamily="{StaticResource PokemonClassic}"
                    FontWeight="Bold"
                    FontSize="12"
                    Click="BtnResetPassword_Click"
                    Margin="44,15,0,16"/>

            </Grid>
        </Border>
    </Border>
</Window>
