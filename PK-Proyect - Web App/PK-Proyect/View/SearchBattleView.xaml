<Window x:Class="PK_Proyect.View.SearchBattleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Batalla"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Padding="16"
        Background="{Binding BackgroundBrush}"
        FontFamily="{StaticResource PokemonClassic}" Height="260" Width="380">
    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <TextBlock Grid.Row="0" Text="Buscar Batalla" FontSize="18" FontWeight="Bold" FontFamily="{StaticResource PokemonClassic}"
               HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <!-- Desafiar -->
            <Grid Grid.Row="1" Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
              Width="120"
              Height="{Binding ButtonHeight}"
              Background="{Binding ButtonBackground}"
              Foreground="{Binding ButtonForeground}"
              Content="Desafiar"
              Command="{Binding DesafiarCommand}"
              FontFamily="{StaticResource PokemonClassic}"
              Margin="0,0,6,0"/>
                <TextBox Grid.Column="2"
               Height="{Binding InputHeight}"
               VerticalAlignment="Center"
                     FontFamily="{StaticResource PokemonClassic}"
               Text="{Binding IdUserToChallenge, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="Introduce ID del usuario a desafiar" Margin="2,0,0,0"/>
            </Grid>

            <!-- Unirse -->
            <Grid Grid.Row="2" Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
              Width="120"
              Height="{Binding ButtonHeight}"
              Background="{Binding ButtonBackground}"
              Foreground="{Binding ButtonForeground}"
              Content="Unirse"
              Command="{Binding UnirseCommand}"
              FontFamily="{StaticResource PokemonClassic}"/>
                <TextBox Grid.Column="2"
               Height="{Binding InputHeight}"
               VerticalAlignment="Center"
                     FontFamily="{StaticResource PokemonClassic}"
               Text="{Binding IdBattleToJoin, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="Introduce ID de la batalla a unirse" Margin="8,0,0,0"/>
            </Grid>

            <!-- Mensaje de estado -->
            <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontSize="11" Foreground="#FF333333"
               HorizontalAlignment="Center" Margin="0,8,0,8" TextWrapping="Wrap"/>

            <!-- Botón cancelar -->
            <Button Grid.Row="3"
            Height="{Binding ButtonHeight}"
            Background="{Binding ButtonBackground}"
            Foreground="{Binding ButtonForeground}"
            Content="Cancelar"
            Command="{Binding CancelCommand}"
            FontFamily="{StaticResource PokemonClassic}" 
            HorizontalAlignment="Center"
            Width="120"
            Margin="0,50,0,0"/>
        </Grid>
    </Border>
</Window>
