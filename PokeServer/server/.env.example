# ============================================================
# PokeCasino-V2  -  Variables de entorno del servidor Flask
# ============================================================
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo ".env" al repositorio.
# ============================================================

# --- MongoDB Atlas ---
# Connection string completa con usuario y contraseña.
# Ejemplo: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_URI=mongodb+srv://<usuario>:<contrasena>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=PokeCasino

# --- JWT ---
# Clave secreta para firmar los tokens JWT.
# Usa una cadena aleatoria larga (mínimo 32 caracteres).
# Puedes generar una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="secret_key_aleatoria_y_segura_para_jwt"
