<Window x:Class="PK_Proyect.View.ForgotPasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recuperar contraseña"
        Height="295" Width="563"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown"
        Background="#FF1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <TextBlock Text="Recuperar contraseña"
                   FontSize="16"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   FontFamily="{StaticResource PokemonClassic}"
                   Margin="0,0,0,10"/>

        <!-- EMAIL -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Correo electrónico:"
                       Foreground="White"
                       Margin="0,0,0,5"
                       FontSize="10"
                       FontFamily="{StaticResource PokemonClassic}"/>
            
            <TextBox x:Name="TxtEmail"
                     Height="28"
                     Background="#FF2D2D2D"
                     Foreground="White"
                     BorderBrush="#FF555555"
                     FontFamily="{StaticResource PokemonClassic}"/>
        </StackPanel>

        <!-- USERNAME -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Nombre de usuario:"
                       Foreground="White"
                       Margin="0,0,0,5"
                       FontSize="10"
                       FontFamily="{StaticResource PokemonClassic}"/>
            
            <TextBox x:Name="TxtUsername"
                     Height="28"
                     Background="#FF2D2D2D"
                     Foreground="White"
                     FontFamily="{StaticResource PokemonClassic}"
                     BorderBrush="#FF555555"/>
        </StackPanel>

        <!-- BOTONES -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Button Content="Recuperar"
                    Width="120" Height="32"
                    Margin="10,0"
                    FontSize="11"
                    Click="BtnRecuperar_Click"
                    Background="#FF3A7AFE"
                    Foreground="White"
                    FontFamily="{StaticResource PokemonClassic}"/>

            <Button Content="Cancelar"
                    Width="120" Height="32"
                    Margin="10,0"
                    Click="BtnCancelar_Click"
                    Background="#FF555555"
                    Foreground="White"
                    FontSize="10"
                    FontFamily="{StaticResource PokemonClassic}"/>
        </StackPanel>

    </Grid>
</Window>
