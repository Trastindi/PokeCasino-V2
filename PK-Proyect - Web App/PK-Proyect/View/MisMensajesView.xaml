<Window x:Class="PK_Proyect.View.MisMensajesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mis Mensajes"
        Height="640" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Título -->
                <RowDefinition Height="*"/>      <!-- Lista scrollable -->
                <RowDefinition Height="Auto"/>   <!-- Botones de acción -->
            </Grid.RowDefinitions>

            <!-- TÍTULO RETRO -->
            <TextBlock Text="Mis Mensajes"
                       Grid.Row="0"
                       FontSize="26"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <!-- LISTA SCROLLABLE -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Mensajes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="5"
                                    Padding="8"
                                    Background="#E0D0A8"
                                    Cursor="Hand">

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#C8B880"/>
                                                <Setter Property="BorderBrush" Value="DarkRed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <!-- Seleccionar al hacer clic -->
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SeleccionarMensajeCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <StackPanel Orientation="Vertical">

                                    <!-- REMITENTE -->
                                    <TextBlock Text="{Binding Remitente}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="Black"/>

                                    <!-- TÍTULO -->
                                    <TextBlock Text="{Binding Titulo}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#333"
                                               Margin="0 2 0 0"/>

                                    <!-- FECHA -->
                                    <TextBlock Text="{Binding Fecha, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="12"
                                               Foreground="#555"
                                               Margin="0 2 0 0"/>

                                    <!-- CONTENIDO -->
                                    <TextBlock Text="{Binding Contenido}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="Black"
                                               TextWrapping="Wrap"
                                               Margin="0 4 0 0"/>

                                    <!-- BADGE DESAFÍO -->
                                    <TextBlock Text="⚔ Desafío de batalla"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="DarkRed"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Margin="0 4 0 0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Tipo}" Value="battle_request">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- BADGE INTERCAMBIO -->
                                    <TextBlock Text="🔄 Solicitud de intercambio"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="DarkBlue"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Margin="0 4 0 0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Tipo}" Value="trade_request">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>

            <!-- BOTONES DE ACCIÓN -->
            <Grid Grid.Row="2" Margin="5 10 5 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Fila 0: Batalla -->
                <Button Grid.Row="0" Grid.Column="0"
                        Content="✔ Aceptar Batalla"
                        Command="{Binding AceptarDesafioCommand}"
                        FontFamily="{StaticResource PokemonClassic}"
                        FontSize="13"
                        Margin="3"
                        Padding="8 6"
                        Background="#CC3333"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="2"/>

                <Button Grid.Row="0" Grid.Column="1"
                        Content="✘ Rechazar Batalla"
                        Command="{Binding RechazarDesafioCommand}"
                        FontFamily="{StaticResource PokemonClassic}"
                        FontSize="13"
                        Margin="3"
                        Padding="8 6"
                        Background="#666"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="2"/>

                <!-- Fila 1: Intercambio -->
                <Button Grid.Row="1" Grid.Column="0"
                        Content="✔ Aceptar Intercambio"
                        Command="{Binding AceptarIntercambioCommand}"
                        FontFamily="{StaticResource PokemonClassic}"
                        FontSize="13"
                        Margin="3"
                        Padding="8 6"
                        Background="#2255AA"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="2"/>

                <Button Grid.Row="1" Grid.Column="1"
                        Content="✘ Rechazar Intercambio"
                        Command="{Binding RechazarIntercambioCommand}"
                        FontFamily="{StaticResource PokemonClassic}"
                        FontSize="13"
                        Margin="3"
                        Padding="8 6"
                        Background="#666"
                        Foreground="White"
                        BorderBrush="Black"
                        BorderThickness="2"/>

            </Grid>

        </Grid>
    </Border>
</Window>
