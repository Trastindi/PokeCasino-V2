<Window x:Class="PK_Proyect.View.Banners.Rutas.Ruta1View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ruta 1"
        Height="605" Width="789"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TÍTULO RETRO -->
            <TextBlock Text="Ruta 1"
                       FontSize="26"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <!-- LISTA DE POKÉMON -->
            <ScrollViewer Grid.Row="1"
              VerticalScrollBarVisibility="Visible"
              Margin="0,32,0,51">

                <ItemsControl ItemsSource="{Binding PokemonDisponibles}">
                    <!-- AQUÍ: panel de items en 3 columnas -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black"
                        BorderThickness="2"
                        Margin="3"
                        Padding="3"
                        Background="#E0D0A8">

                                <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                                    <Image Source="{Binding Sprite}"
                               Width="48" Height="48"
                               Margin="0 0 10 0"/>

                                    <TextBlock Text="{Binding Nombre}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="Black"/>
                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- BOTONES RETRO -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0 15 0 0">

                <!-- FICHAS -->

                <Button Content="Pokémon"
                        Width="120" Height="40"
                        Margin="10 0"
                        FontFamily="{StaticResource PokemonClassic}"
                        Background="#D8C090"
                        Command="{Binding MostrarPokemonCommand}"/>

                <Button Content="Tirar x1"
                        Width="120" Height="40"
                        Margin="10 0"
                        FontFamily="{StaticResource PokemonClassic}"
                        Background="#D8C090"
                        Command="{Binding Tirar1Command}"/>

                <Button Content="Tirar x10"
                        Width="120" Height="40"
                        Margin="10 0"
                        FontFamily="{StaticResource PokemonClassic}"
                        Background="#D8C090"
                        Command="{Binding Tirar10Command}"/>

                <!-- BOTÓN HISTORIAL -->
                <Button Content="Historial"
                        Width="120" Height="40"
                        Margin="10 0"
                        FontFamily="{StaticResource PokemonClassic}"
                        Background="#D8C090"
                        Command="{Binding HistorialCommand}"/>

                <!-- FICHAS -->
            </StackPanel>

            <TextBlock Text="{Binding Fichas}"
                           FontSize="16"
                           FontFamily="{StaticResource PokemonClassic}"
                           Foreground="Gold" Margin="617,15,7,2"/>

        </Grid>
    </Border>
</Window>


