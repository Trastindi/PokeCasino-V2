<Window x:Class="PK_Proyect.Views.ResultadoTiradasView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resultados de la Tirada"
        Height="520" Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <StackPanel Margin="10">

            <TextBlock Text="{Binding Titulo}"
                       FontSize="20"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 12"
                       Foreground="Black"/>

            <ScrollViewer Height="380">
                <ItemsControl ItemsSource="{Binding Pokemones}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black" BorderThickness="2" Margin="6" Padding="8" Background="#E0D0A8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Width="64" Height="64"
                                           Source="{Binding SpriteUrl}"
                                           Stretch="Uniform"
                                           Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding Nombre}"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontWeight="Bold"
                                               Foreground="Black"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Content="Cerrar"
                    Width="100" Height="30"
                    FontFamily="{StaticResource PokemonClassic}"
                    HorizontalAlignment="Center"
                    Margin="0 10 0 0"
                    Background="#D8C090"
                    Click="Cerrar"/>
        </StackPanel>
    </Border>
</Window>
