<Window x:Class="PK_Proyect.View.SeleccionarPokemonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elige un Pokémon para intercambiar"
        Width="720" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Búsqueda -->
            <RowDefinition Height="*"/>     <!-- Lista -->
            <RowDefinition Height="Auto"/> <!-- Botones -->
        </Grid.RowDefinitions>

        <!-- Búsqueda -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
            <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="0 0 8 0"/>
            <TextBox Width="220"
                     Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"/>
            <Button Content="✕" Margin="4 0 0 0" Padding="6 2"
                    Click="BtnLimpiar_Click"/>
        </StackPanel>

        <!-- Grid de tarjetas de Pokémon -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding PokemonFiltrado}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="130" Height="150" Margin="6"
                                BorderBrush="#ccc" BorderThickness="1" CornerRadius="8"
                                Background="White" Cursor="Hand"
                                MouseLeftButtonUp="PokemonCard_Click">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8">
                                <Image Source="{Binding ImagenUrl}" Width="64" Height="64"
                                       Stretch="Uniform" Margin="0 0 0 6"/>
                                <TextBlock Text="{Binding Nombre}" FontWeight="Bold"
                                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding TipoPrincipal}" FontSize="11"
                                           Foreground="Gray" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Botones inferiores -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 12 0 0">
            <Button Content="Ver detalles" Padding="10 4" Margin="0 0 8 0"
                    Click="BtnVerDetalle_Click"
                    IsEnabled="{Binding HaySeleccion}"/>
            <Button Content="✔ Elegir este Pokémon" Padding="10 4" Margin="0 0 8 0"
                    Background="#2ecc71" Foreground="White"
                    Click="BtnElegir_Click"
                    IsEnabled="{Binding HaySeleccion}"/>
            <Button Content="Cancelar" Padding="10 4"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
