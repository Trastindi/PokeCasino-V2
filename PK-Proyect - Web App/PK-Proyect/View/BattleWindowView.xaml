<Window x:Class="PK_Proyect.View.BattleWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batalla Pokémon"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="780" Height="500"
        Background="{Binding BackgroundBrush}"
        FontFamily="{StaticResource PokemonClassic}"
        KeyDown="Window_KeyDown"
        Closed="Window_Closed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Botón de acción principal (azul) -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="Black" BorderThickness="2" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#FF5AA0FF"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="bd" Property="Background" Value="#FF2B6FD6"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#FFBDBDBD"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de movimiento (oscuro, alineado izquierda) -->
        <Style x:Key="MoveButton" TargetType="Button">
            <Setter Property="Background" Value="#FF1E3A5F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                BorderBrush="Black" BorderThickness="2" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#FF2E5A8E"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="bd" Property="Background" Value="#FF0F2440"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tarjeta de Pokémon seleccionable -->
        <!-- NOTA: PickCard ya NO se asigna como Style="{StaticResource PickCard}" en los Border
             de las DataTemplate. En su lugar se usa Border.Style directamente con BasedOn.
             Esto evita el error XLS0501 "Style ya establecida más de una vez". -->
        <Style x:Key="PickCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="Black" BorderThickness="4" Background="#FFF3C04A" Padding="10">
        <Grid>

            <!-- ===========================================================
                 PANEL 1: READY — Selección inicial de Pokémon
                 =========================================================== -->
            <Grid Visibility="{Binding ShowPokemonPicker, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="¡Elige tu Pokémon para el combate!"
                           FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Equipo}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- FIX XLS0501/XDG0039: NO Style=PickCard + Border.Style al mismo tiempo.
                                     Usar solo Border.Style con BasedOn para heredar y añadir triggers. -->
                                <Border Width="130" Height="155">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource PickCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#FFD4EDFF"/>
                                                    <Setter Property="BorderBrush" Value="#FF3B82F6"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ConfirmPickCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding ImagenUrl}" Width="64" Height="64" Stretch="Uniform" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Nombre}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock FontSize="10" Foreground="Gray" HorizontalAlignment="Center">
                                            <Run Text="Nv."/><Run Text="{Binding Nivel}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="Gray" HorizontalAlignment="Center">
                                            <Run Text="{Binding HpActual}"/><Run Text="/"/><Run Text="{Binding HpMax}"/><Run Text=" PS"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <TextBlock Text="{Binding BattleMessage}" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#FF666666" FontSize="11"/>
                    <Button Content="► Combatir" Style="{StaticResource RoundedButton}"
                            Command="{Binding ConfirmPickCommand}" IsEnabled="{Binding CanConfirmPick}"
                            Padding="16,8"/>
                </StackPanel>
            </Grid>

            <!-- ===========================================================
                 PANEL 2: CHOOSING_ACTION — Combate activo
                 =========================================================== -->
            <Grid Visibility="{Binding ShowBattle, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- rival -->
                    <RowDefinition Height="*"/>      <!-- log -->
                    <RowDefinition Height="Auto"/>   <!-- jugador + menú -->
                </Grid.RowDefinitions>

                <!-- Rival -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,6,0,0">
                        <TextBlock Text="{Binding OpponentName}" FontWeight="Bold" FontSize="13"/>
                        <TextBlock FontSize="12" Margin="0,4,0,0"><Run Text="Nv: "/><Run Text="{Binding OpponentLevel}"/></TextBlock>
                        <ProgressBar Width="180" Height="12" Value="{Binding OpponentHpPercent, Mode=OneWay}" Maximum="100"
                                     Foreground="#FF2ECC71" Background="#FFBDBDBD" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding OpponentHpText}" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2" Background="#FFF8F0D8"
                            CornerRadius="6" Padding="6" Height="110">
                        <Image Source="{Binding OpponentSprite}" Stretch="Uniform" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Log del turno -->
                <Border Grid.Row="1" Background="#22000000" CornerRadius="4" Padding="6" Margin="0,4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScroll">
                        <ItemsControl ItemsSource="{Binding TurnLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="10" Foreground="#FF222222" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Jugador + menú -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sprite + info jugador -->
                    <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2" Background="#FFF8F0D8"
                            CornerRadius="6" Padding="6" Height="150">
                        <StackPanel>
                            <Image Source="{Binding PlayerSprite}" Width="90" Height="90" Stretch="Uniform"/>
                            <TextBlock Text="{Binding PlayerName}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="10" HorizontalAlignment="Center"><Run Text="Nv: "/><Run Text="{Binding PlayerLevel}"/></TextBlock>
                            <ProgressBar Width="140" Height="10" Value="{Binding PlayerHpPercent, Mode=OneWay}" Maximum="100"
                                         Foreground="#FF2ECC71" Background="#FFBDBDBD" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PlayerHpText}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- FIX XDG0040: Border solo puede tener un hijo directo.
                         Envolver ambos Grid (acciones y movimientos) en un solo Grid padre. -->
                    <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2" Background="#FFF8F0D8"
                            CornerRadius="6" Padding="8" Margin="8,0,0,0">
                        <Grid>
                            <!-- Acciones -->
                            <Grid Visibility="{Binding ShowActions, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource RoundedButton}" Content="Luchar"
                                        Command="{Binding OpenMovesCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedButton}" Content="PKMN"
                                        Command="{Binding SwitchPokemonCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource RoundedButton}" Content="OBJ."
                                        Command="{Binding UseItemCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedButton}" Content="ESC"
                                        Command="{Binding RunCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                            </Grid>

                            <!-- Movimientos -->
                            <Grid Visibility="{Binding ShowMoves, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource MoveButton}"
                                        Command="{Binding UseMoveCommand}" Margin="4" Height="40"
                                        CommandParameter="{Binding PlayerMoves[0]}"
                                        Content="{Binding PlayerMoves[0].Name}"
                                        IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource MoveButton}"
                                        Command="{Binding UseMoveCommand}" Margin="4" Height="40"
                                        CommandParameter="{Binding PlayerMoves[1]}"
                                        Content="{Binding PlayerMoves[1].Name}"
                                        IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource MoveButton}"
                                        Command="{Binding UseMoveCommand}" Margin="4" Height="40"
                                        CommandParameter="{Binding PlayerMoves[2]}"
                                        Content="{Binding PlayerMoves[2].Name}"
                                        IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource MoveButton}"
                                        Command="{Binding UseMoveCommand}" Margin="4" Height="40"
                                        CommandParameter="{Binding PlayerMoves[3]}"
                                        Content="{Binding PlayerMoves[3].Name}"
                                        IsEnabled="{Binding IsBattleActive}"/>
                                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                        Style="{StaticResource RoundedButton}" Content="← Volver"
                                        Command="{Binding BackToActionsCommand}" Margin="4,8,4,0" Height="32"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===========================================================
                 PANEL 3: WAITING_SWITCH — Cambio forzado
                 =========================================================== -->
            <Grid Visibility="{Binding ShowForcedSwitch, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding BattleMessage}"
                           FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"
                           Foreground="#FFC0392B" Margin="0,0,0,12" TextWrapping="Wrap"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Equipo}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- FIX XLS0501: mismo patrón que Panel 1 -->
                                <Border Width="130" Height="155">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource PickCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#FFD4EDFF"/>
                                                    <Setter Property="BorderBrush" Value="#FF3B82F6"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HpActual}" Value="0">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ConfirmSwitchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding ImagenUrl}" Width="64" Height="64" Stretch="Uniform" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Nombre}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock FontSize="10" Foreground="Gray" HorizontalAlignment="Center">
                                            <Run Text="{Binding HpActual}"/><Run Text="/"/><Run Text="{Binding HpMax}"/><Run Text=" PS"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2" Content="► Enviar Pokémon" Style="{StaticResource RoundedButton}"
                        Command="{Binding ConfirmSwitchCommand}" IsEnabled="{Binding CanConfirmPick}"
                        HorizontalAlignment="Right" Padding="16,8" Margin="0,8,0,0"/>
            </Grid>

            <!-- ===========================================================
                 PANEL 4: FINISHED — Resultado final
                 =========================================================== -->
            <Grid Visibility="{Binding ShowFinished, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="32">
                    <TextBlock Text="{Binding FinishMessage}"
                               FontWeight="Bold" FontSize="22"
                               HorizontalAlignment="Center"
                               Foreground="#FF2C3E50"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <Border Background="#22000000" CornerRadius="4" Padding="8" MaxHeight="160" Margin="0,0,0,20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TurnLog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#FF333333" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Button Content="Cerrar" Style="{StaticResource RoundedButton}"
                            Command="{Binding CloseCommand}" Padding="24,10"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
