    <None Remove="Images\fondo.jpg" />
    <None Remove="Images\gender_dialog_frame.png" />
    <None Remove="Images\logo.ico" />
    <None Remove="Images\logo.png" />
    <None Remove="Images\MapaKanto.webp" />
    <None Remove="Images\messages_ico.png" />
    <None Remove="Images\Oak.png" />
    <None Remove="Images\perfil.webp" />
    <None Remove="Images\PokeAdmin.jpg" />
    <None Remove="Images\PokeYellow2.webp" />
    <None Remove="Images\Pueblo_Paleta_RfVh.png" />
    <None Remove="Images\SlotMachine.png" />
    <None Remove="Images\SlotMachineNumbers.png" />
    <None Remove="Images\SlotMachineSymbols.png" />
