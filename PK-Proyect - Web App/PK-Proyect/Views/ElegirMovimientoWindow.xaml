<Window x:Class="PK_Proyect.Views.ElegirMovimientoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo movimiento" Height="280" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock x:Name="TxtMensaje" TextWrapping="Wrap" FontSize="14"
                   Margin="0,0,0,16" />
        <Button x:Name="BtnMov0" Height="38" Margin="0,4" FontSize="13"
                Click="Btn_Click" Tag="0" />
        <Button x:Name="BtnMov1" Height="38" Margin="0,4" FontSize="13"
                Click="Btn_Click" Tag="1" />
        <Button x:Name="BtnMov2" Height="38" Margin="0,4" FontSize="13"
                Click="Btn_Click" Tag="2" />
        <Button x:Name="BtnMov3" Height="38" Margin="0,4" FontSize="13"
                Click="Btn_Click" Tag="3" />
    </StackPanel>
</Window>
