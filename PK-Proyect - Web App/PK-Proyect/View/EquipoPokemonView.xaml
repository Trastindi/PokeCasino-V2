<Window x:Class="PK_Proyect.View.EquipoPokemonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PK_Proyect.Converters"
        Title="Gestionar Equipos"
        Height="560" Width="480"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue"   Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed"    Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox"    Color="#FFF5F2DF"/>
        <SolidColorBrush x:Key="PkGreen"  Color="#1a8a2e"/>

        <!-- Converters -->
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="RetroBtn" TargetType="Button">
            <Setter Property="FontFamily"       Value="{StaticResource PokemonClassic}"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Foreground"       Value="{StaticResource PkWhite}"/>
            <Setter Property="Background"       Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource PkRed}"/>
            <Setter Property="BorderThickness"  Value="3"/>
            <Setter Property="Padding"          Value="8,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <Style x:Key="RetroBtnGreen" TargetType="Button" BasedOn="{StaticResource RetroBtn}">
            <Setter Property="Background"    Value="{StaticResource PkGreen}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource PkBlue}"/>
        </Style>

        <Style x:Key="EquipoItem" TargetType="Border">
            <Setter Property="Background"       Value="#E0D0A8"/>
            <Setter Property="BorderBrush"      Value="Black"/>
            <Setter Property="BorderThickness"  Value="2"/>
            <Setter Property="Margin"           Value="4,4,4,0"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18" BorderThickness="3" BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/PokeYellow2.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="15" BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Barra superior ── -->
                <Border Grid.Row="0" Background="{StaticResource PkYellow}"
                        CornerRadius="15,15,0,0">
                    <Grid>
                        <TextBlock Text="MIS EQUIPOS"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource PkBlue}"/>
                        <Button Content="X"
                                FontFamily="{StaticResource PokemonClassic}"
                                FontSize="18"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                HorizontalAlignment="Right" Margin="0,4,8,4"
                                Click="btnClose_Click"/>
                    </Grid>
                </Border>

                <!-- ── Botón Crear Equipo: visible cuando ModoSeleccion = false ── -->
                <Button Grid.Row="1"
                        Content="+ Crear Equipo"
                        Style="{StaticResource RetroBtn}"
                        Command="{Binding CrearEquipoCommand}"
                        Margin="12,10,12,4"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding ModoSeleccion,
                                     Converter={StaticResource InverseBoolToVis}}"/>

                <!-- ── Subtítulo modo selección: visible cuando ModoSeleccion = true ── -->
                <TextBlock Grid.Row="1"
                           Text="Elige el equipo con el que entrarás a batalla:"
                           FontFamily="{StaticResource PokemonClassic}"
                           FontSize="12" Foreground="{StaticResource PkBlue}"
                           TextWrapping="Wrap"
                           Margin="12,10,12,4"
                           Visibility="{Binding ModoSeleccion,
                                        Converter={StaticResource BoolToVis}}"/>

                <!-- ── Lista de equipos ── -->
                <ScrollViewer Grid.Row="2" Margin="8,4,8,10"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Equipos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EquipoItem}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                            Command="{Binding DataContext.VerDetalleCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontFamily="{StaticResource PokemonClassic}"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="Black"/>
                                            <TextBlock FontFamily="{StaticResource PokemonClassic}"
                                                       FontSize="11" Foreground="#555555">
                                                <Run Text="{Binding PokemonIds.Count, Mode=OneWay, StringFormat='({0} Pokémon)'}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Modo selección: botón Elegir Equipo -->
                                        <Button Grid.Column="1"
                                                Content="Elegir Equipo"
                                                Style="{StaticResource RetroBtnGreen}"
                                                FontSize="11"
                                                Padding="8,4"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.ElegirEquipoCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding DataContext.ModoSeleccion,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                             Converter={StaticResource BoolToVis}}"/>

                                        <!-- Modo gestión: flecha indicadora -->
                                        <TextBlock Grid.Column="1"
                                                   Text="&#9654;"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource PkBlue}"
                                                   Margin="8,0,0,0"
                                                   Visibility="{Binding DataContext.ModoSeleccion,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                Converter={StaticResource InverseBoolToVis}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <!-- Empty state -->
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Equipos.Count, Mode=OneWay}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Margin="0,40,0,0">
                                                        <TextBlock Text="No tienes equipos aún."
                                                                   FontFamily="{StaticResource PokemonClassic}"
                                                                   FontSize="13"
                                                                   Foreground="#888"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="¡Crea tu primer equipo!"
                                                                   FontFamily="{StaticResource PokemonClassic}"
                                                                   FontSize="11"
                                                                   Foreground="#AAA"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>
    </Border>
</Window>
