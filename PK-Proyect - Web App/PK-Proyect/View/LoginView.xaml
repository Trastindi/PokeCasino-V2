<Window x:Class="PK_Proyect.View.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PK_Proyect.View"
        mc:Ignorable="d"
        Title="LoginView" Height="530" Width="800"
        Icon="/Images/logo.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue"   Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed"    Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox"    Color="#FFF5F2DF" Opacity="0.7"/>

        <Style x:Key="RetroText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PkBlue}"/>
        </Style>

        <Style x:Key="RetroBox" TargetType="Control">
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Background"      Value="{StaticResource PkBox}"/>
            <Setter Property="Foreground"      Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Padding"         Value="6,4"/>
        </Style>

        <Style x:Key="RetroButton" TargetType="Button">
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="{StaticResource PkWhite}"/>
            <Setter Property="Background"      Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PkRed}"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="Cursor"          Value="Hand">
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RetroRoundButton" TargetType="Button">
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Foreground"      Value="{StaticResource PkWhite}"/>
            <Setter Property="Background"      Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Width"           Value="20"/>
            <Setter Property="Height"          Value="20"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20" BorderThickness="3" BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/PokeYellow2.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="17" BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}"
                Opacity="0.98">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Barra superior -->
                <Border Grid.Row="0" Background="{StaticResource PkYellow}"
                        Height="30" CornerRadius="15,15,0,0">
                    <Grid VerticalAlignment="Bottom">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="6"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="LOG IN"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   Style="{StaticResource RetroText}"
                                   FontSize="12" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Button x:Name="btnMinimize" Content="-"
                                Style="{StaticResource RetroRoundButton}"
                                Grid.Column="1" Click="btnMinimize_Click"/>
                        <Button x:Name="btnClose" Content="X"
                                Style="{StaticResource RetroRoundButton}"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                Grid.Column="2" Click="btnClose_Click"/>
                    </Grid>
                </Border>

                <!-- Contenido principal -->
                <StackPanel Width="260" Grid.Row="1"
                            Orientation="Vertical" Margin="0,32,0,0"
                            HorizontalAlignment="Center">

                    <Image Source="/Images/logo.png" Stretch="Fill"
                           Height="100" Width="248"/>

                    <TextBlock Text="Bienvenido al sistema"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               FontSize="12" Opacity="0.8"
                               TextAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="USUARIO"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               FontSize="12" Margin="0,10,0,4"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RetroBox}"
                             Height="35" VerticalContentAlignment="Center"/>

                    <TextBlock Text="CONTRASEÑA"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               FontSize="12" Margin="0,12,0,4"/>

                    <!-- x:Name para pasarlo como CommandParameter al botón -->
                    <PasswordBox x:Name="PbPassword"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 Style="{StaticResource RetroBox}"
                                 Height="30" VerticalContentAlignment="Center"/>

                    <Button Content="LOGIN"
                            Style="{StaticResource RetroButton}"
                            Margin="0,18,0,0" Height="40"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=PbPassword}"/>

                    <TextBlock Text="¿Contraseña olvidada?"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               FontSize="11" Cursor="Hand"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               MouseDown="ForgotPassword_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
