<Window x:Class="PK_Proyect.View.MainMenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        MouseDown="Window_MouseDown"
        Title="Menu Principal"
        Height="600" Width="1013"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue" Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed" Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox" Color="#FFF5F2DF" Opacity="0.7"/>

        <Style x:Key="RetroButton" TargetType="Button">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource PkWhite}"/>
            <Setter Property="Background" Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PkRed}"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="RetroText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PkBlue}"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderThickness="3"
            BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/PokeYellow2.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="15"
                BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}"
                Opacity="0.98">

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Barra superior -->
                <Border Grid.Row="0"
                        Background="{StaticResource PkYellow}"
                        CornerRadius="15,15,0,0" Margin="-20,-20,-20,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="MENU PRINCIPAL"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Style="{StaticResource RetroText}"/>




                        <Button Content="X"
                                FontFamily="{StaticResource PokemonClassic}"
                                FontSize="20"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                Click="btnClose_Click" Grid.ColumnSpan="2" Margin="933,5,10,5"/>
                    </Grid>
                </Border>

                <TextBlock  Text="{Binding UsuarioConectado.Username, StringFormat=Usuario Conectado: {0}}"
                            FontFamily="{StaticResource PokemonClassic}"
                            FontSize="12"
                            FontWeight="Bold"
                            Style="{StaticResource RetroText}"
                            Margin="10,480,382,0"
                            Grid.Row="1"></TextBlock>


                <!-- Contenido -->
                <StackPanel Grid.Row="1"
                            Margin="0,20,0,0"
                            Width="364"
                            HorizontalAlignment="Center">

                    <Image Source="/Images/logo.png"
                           Height="130"
                           Margin="0,0,0,20"/>

                    <Button Content="🎰  Casino"
                            FontFamily="{StaticResource PokemonClassic}"
                            Style="{StaticResource RetroButton}"
                            Command="{Binding AbrirCasinoCommand}"/>

                    <Button Content="🗺️  Mapa"
                            FontFamily="{StaticResource PokemonClassic}"
                            Style="{StaticResource RetroButton}"
                            Command="{Binding AbrirMapaCommand}"/>

                    <Button Content="◓  Equipo Pokémon"
                            FontFamily="{StaticResource PokemonClassic}"
                            Style="{StaticResource RetroButton}"
                            Command="{Binding AbrirEquipoCommand}"/>

                    <Button Content="🏅  Medallas"
                            FontFamily="{StaticResource PokemonClassic}"
                            Style="{StaticResource RetroButton}"
                            Command="{Binding AbrirMedallasCommand}"/>


                </StackPanel>

                <Button Content="⏻"
                    Style="{StaticResource RetroButton}"
                    Background="{StaticResource PkBlue}"
                    BorderBrush="{StaticResource PkRed}"
                    Foreground="{StaticResource PkRed}"
                    FontFamily="{StaticResource PokemonClassic}"
                    FontSize="40"
                    FontWeight="Bold"
                    Command="{Binding CerrarSesionCommand}"
                    Width="80"
                    Height="80"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="881,10,0,418"
                    Grid.Row="1">

                    <Button.Template>

                        <ControlTemplate TargetType="Button">

                            <Grid>

                                <Ellipse Fill="{TemplateBinding Background}"
                                 Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="2"/>

                                <ContentPresenter
                                ContentSource="Content"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextElement.FontFamily="{TemplateBinding FontFamily}"
                                TextElement.FontSize="{TemplateBinding FontSize}"
                                Margin="0,0,0,15"/>

                            </Grid>

                        </ControlTemplate>

                    </Button.Template>

                </Button>



                <Button Content="👤"
                    Style="{StaticResource RetroButton}"
                    Background="{StaticResource PkBlue}"
                    BorderBrush="{StaticResource PkRed}"
                    Foreground="{StaticResource PkWhite}"
                    FontFamily="{StaticResource PokemonClassic}"
                    FontSize="36"
                    Width="80"
                    Height="80"
                    Command="{Binding AbrirPerfilCommand}" 
                    Margin="0,12,881,416"
                    
                    Grid.Row="1" 
                    RenderTransformOrigin="0.5,0.5">

                    <Button.Template>

                        <ControlTemplate 
        
                            TargetType="Button">

                            <Grid>

                                <Ellipse Fill="{TemplateBinding Background}" 
                                    Stroke="{TemplateBinding BorderBrush}" 
                                    StrokeThickness="2"/>

                                <ContentPresenter
                                    ContentSource="Content"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    TextElement.Foreground="{TemplateBinding Foreground}"
                                    TextElement.FontFamily="{TemplateBinding FontFamily}"
                                    TextElement.FontSize="{TemplateBinding FontSize}"
                                    Margin="0,0,0,15"/>

                            </Grid>

                        </ControlTemplate>

                    </Button.Template>

                </Button>

            </Grid>

        </Border>
    </Border>
</Window>
