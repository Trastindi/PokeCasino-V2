<Window x:Class="PK_Proyect.View.SignupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PK_Proyect.View"
        mc:Ignorable="d"
        KeyDown="Window_KeyDown"
        Title="SignupView" Height="600" Width="950">

    <Grid>
        
        
      <MediaElement Name="BackgroundMusic"
      Source="resources/SignUp_ost.mp3"
      LoadedBehavior="Play"
      UnloadedBehavior="Manual"
      Volume="1.0"
      
      MediaEnded="BackgroundMusic_MediaEnded"
      
      Grid.RowSpan="1" Grid.ColumnSpan="1"/>
        <Image x:Name="imgOak" HorizontalAlignment="Left" Height="81" VerticalAlignment="Top" Width="67" Margin="684,117,0,0" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="3" ScaleY="3"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <Label x:Name="LblPokemonText"
               FontFamily="{StaticResource PokemonClassic}"
               FontSize="30"
               HorizontalAlignment="Center"
               VerticalAlignment="Top" Margin="0,361,0,0" Height="205" Width="930"
               Padding="40, 30">
            <Label.Background>
                <ImageBrush ImageSource="/Images/dialog_frame.png"/>
            </Label.Background>
        </Label>
        <Label x:Name="LblGenderDialog"
               FontFamily="{StaticResource PokemonClassic}"
               FontSize="48"
               Content="Chico&#xD;&#xA;Chica&#xD;&#xA;"
               HorizontalAlignment="Left"
               Margin="10,10,0,0" VerticalAlignment="Top" Height="229" Width="352"
               Padding="75, 30" Visibility="Hidden">
            <Label.Background>
                <ImageBrush ImageSource="/Images/gender_dialog_frame.png"/>
            </Label.Background>
        </Label>

        <Image x:Name="BoyArrow" Margin="43,55,864,473" Source="/Images/arrow.png" Stretch="Fill" Visibility="Hidden"/>
        <Image x:Name="GirlArrow" Margin="43,138,864,390" Source="/Images/arrow.png" Stretch="Fill" Visibility="Hidden"/>

        <WrapPanel x:Name="LblSelectNameLetter" Margin="0,133,0,87" Visibility="Hidden">
            <WrapPanel.Background>
                <ImageBrush ImageSource="/Images/dialog_frame.png"/>
            </WrapPanel.Background>
        </WrapPanel>
        <Label x:Name="LblUpperCase" Content="LOWER CASE" HorizontalAlignment="Left" Height="48" Margin="68,497,0,0" VerticalAlignment="Top" Width="260" FontFamily="{StaticResource PokemonClassic}" FontSize="24" Visibility="Hidden"/>
        <WrapPanel x:Name="WpAlphabet" Margin="0,166,0,92" Width="910" Visibility="Hidden">
            <WrapPanel.Background>
                <ImageBrush ImageSource="/Images/dialog_frame.png"/>
            </WrapPanel.Background>
        </WrapPanel>
        <WrapPanel x:Name="WpName" Margin="10,22,20,451" Visibility="Hidden">
            <Label 
                FontFamily="{StaticResource ResourceKey=PokemonClassic}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Content="-"
                Height="111"
                Width="73"
                FontSize="72"
                Margin="21,0,21,0"
                Padding="14,5,5,5"/>
        </WrapPanel>

    </Grid>
</Window>