<Window x:Class="PK_Proyect.View.BattleWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batalla"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Padding="12"
        Background="{Binding BackgroundBrush}"
        FontFamily="{StaticResource PokemonClassic}"
        MinWidth="760" MinHeight="420"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                  Background="{TemplateBinding Background}"
                  CornerRadius="8"
                  BorderBrush="Black"
                  BorderThickness="2"
                  SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True"
                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF5AA0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF2B6FD6"/>
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#FFBDBDBD"/>
                                <Setter Property="Foreground" Value="#FF7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MoveButton" TargetType="Button">
            <Setter Property="Background" Value="#FF1E3A5F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="Black"
                                BorderThickness="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF2E5A8E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF0F2440"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border BorderBrush="Black" BorderThickness="4" Background="#FFF3C04A" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- TOP: rival -->
                <RowDefinition Height="*"/>     <!-- ESPACIO VACÍO -->
                <RowDefinition Height="Auto"/>  <!-- BOTTOM: jugador + menú -->
            </Grid.RowDefinitions>

            <!-- TOP: Rival (info a la izquierda del sprite) -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Top" Margin="0,6,532,0" Width="200">
                    <TextBlock Text="{Binding OpponentName}" FontWeight="Bold" FontSize="13"/>
                    <TextBlock FontSize="12" Margin="0,4,0,0"><Run Text="Nv: "/><Run Text="{Binding OpponentLevel}"/></TextBlock>
                    <ProgressBar Width="180" Height="14" Value="{Binding OpponentHpPercent, Mode=OneWay}" Maximum="100"
                        Foreground="#FF2ECC71" Background="#FFBDBDBD" Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="2" Background="#FFF8F0D8"
                    CornerRadius="6" Padding="6" HorizontalAlignment="Left" Width="294" Height="120" Margin="31,0,0,0">
                    <Image Source="{Binding OpponentSprite}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- MENSAJE DE BATALLA -->
            <Grid Grid.Row="1">
                <TextBlock Text="{Binding BattleMessage}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FF333333"/>
            </Grid>

            <!-- BOTTOM: sprite jugador + panel derecho -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="Black" BorderThickness="2" Background="#FFF8F0D8"
                CornerRadius="6" Padding="8" HorizontalAlignment="Left" Width="360" Height="160" Margin="0,56,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{Binding PlayerSprite}" Width="140" Height="140" Stretch="Uniform"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Grid.ColumnSpan="3" Margin="81,-9,0,0"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Width="360">
                    <!-- INFO JUGADOR -->
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Margin="0,0,0,8" Width="320">
                        <TextBlock Text="{Binding PlayerName}" FontWeight="Bold" FontSize="13" RenderTransformOrigin="0.5,0.5" Width="50">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock FontSize="12"><Run Text="Nv: "/><Run Text="{Binding PlayerLevel}"/></TextBlock>
                        <ProgressBar Width="220" Height="14" Value="{Binding PlayerHpPercent, Mode=OneWay}" Maximum="100"
                         Foreground="#FF2ECC71" Background="#FFBDBDBD" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding PlayerHpText}" FontSize="11" HorizontalAlignment="Right" Margin="0,4,0,0" RenderTransformOrigin="0.5,0.5" Width="220">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="-1"/>
                                    <SkewTransform/>
                                    <RotateTransform/>
                                    <TranslateTransform/>
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>

                    <!-- PANEL CONTENEDOR: alterna entre ACCIONES y MOVIMIENTOS -->
                    <Border BorderBrush="Black" BorderThickness="2" Background="#FFF8F0D8" CornerRadius="6" Padding="8">

                        <!-- MENÚ DE ACCIONES (visible cuando ShowActions = true) -->
                        <Grid Visibility="{Binding ShowActions, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource RoundedButton}" Content="Luchar"
                                    Command="{Binding OpenMovesCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedButton}" Content="PKMN"
                                    Command="{Binding SwitchPokemonCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource RoundedButton}" Content="OBJ."
                                    Command="{Binding UseItemCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedButton}" Content="ESC"
                                    Command="{Binding RunCommand}" Margin="6" Height="44" IsEnabled="{Binding IsBattleActive}"/>
                        </Grid>

                        <!-- PANEL DE MOVIMIENTOS (visible cuando ShowMoves = true) -->
                        <Grid Visibility="{Binding ShowMoves, Converter={StaticResource BoolToVis}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Hint Backspace -->
                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="[⌫ Backspace = volver]"
                                       FontSize="9" Foreground="#FF888888"
                                       HorizontalAlignment="Right" Margin="0,0,4,4"/>

                            <!-- Movimientos 1-4 en cuadrícula 2x2 -->
                            <Button Grid.Row="1" Grid.Column="0"
                                    Style="{StaticResource MoveButton}"
                                    Command="{Binding UseMoveCommand}"
                                    CommandParameter="{Binding PlayerMoves[0]}"
                                    Margin="4" Height="44" IsEnabled="{Binding IsBattleActive}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding PlayerMoves[0].Name}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock FontSize="9">
                                        <Run Text="{Binding PlayerMoves[0].Type}"/>
                                        <Run Text=" PP:"/>
                                        <Run Text="{Binding PlayerMoves[0].Pp}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding PlayerMoves[0].MaxPp}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.Column="1"
                                    Style="{StaticResource MoveButton}"
                                    Command="{Binding UseMoveCommand}"
                                    CommandParameter="{Binding PlayerMoves[1]}"
                                    Margin="4" Height="44" IsEnabled="{Binding IsBattleActive}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding PlayerMoves[1].Name}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock FontSize="9">
                                        <Run Text="{Binding PlayerMoves[1].Type}"/>
                                        <Run Text=" PP:"/>
                                        <Run Text="{Binding PlayerMoves[1].Pp}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding PlayerMoves[1].MaxPp}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="2" Grid.Column="0"
                                    Style="{StaticResource MoveButton}"
                                    Command="{Binding UseMoveCommand}"
                                    CommandParameter="{Binding PlayerMoves[2]}"
                                    Margin="4" Height="44" IsEnabled="{Binding IsBattleActive}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding PlayerMoves[2].Name}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock FontSize="9">
                                        <Run Text="{Binding PlayerMoves[2].Type}"/>
                                        <Run Text=" PP:"/>
                                        <Run Text="{Binding PlayerMoves[2].Pp}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding PlayerMoves[2].MaxPp}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="2" Grid.Column="1"
                                    Style="{StaticResource MoveButton}"
                                    Command="{Binding UseMoveCommand}"
                                    CommandParameter="{Binding PlayerMoves[3]}"
                                    Margin="4" Height="44" IsEnabled="{Binding IsBattleActive}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding PlayerMoves[3].Name}" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock FontSize="9">
                                        <Run Text="{Binding PlayerMoves[3].Type}"/>
                                        <Run Text=" PP:"/>
                                        <Run Text="{Binding PlayerMoves[3].Pp}"/>
                                        <Run Text="/"/>
                                        <Run Text="{Binding PlayerMoves[3].MaxPp}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Button>
                        </Grid>

                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
