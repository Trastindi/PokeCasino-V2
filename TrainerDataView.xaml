<Window x:Class="PK_Proyect.View.TrainerDataView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Datos del Entrenador"
        Height="665" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue" Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed" Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox" Color="#FFF5F2DF" Opacity="0.7"/>

        <Style x:Key="RetroText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PkBlue}"/>
        </Style>

        <Style x:Key="RetroBox" TargetType="Control">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{StaticResource PkBox}"/>
            <Setter Property="Foreground" Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="RetroButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource PkWhite}"/>
            <Setter Property="Background" Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PkRed}"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderThickness="3"
            BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/trainer.jpg" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="15"
                BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}"
                Opacity="0.98" Margin="0,0,0,-3">

            <Grid Margin="20,20,20,-3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Barra superior -->
                <Border Grid.Row="0"
                        Background="{StaticResource PkYellow}"
                        CornerRadius="15,15,0,0" Margin="-20,-20,-18,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="DATOS DEL ENTRENADOR"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Style="{StaticResource RetroText}"/>

                        <Button Content="X"
                                Grid.Column="2"
                                Width="24" Height="24"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                Command="{Binding CancelarCommand}"/>
                    </Grid>
                </Border>

                <!-- Contenido -->
                <StackPanel Grid.Row="1"
                            Margin="0,20,0,0"
                            Width="350"
                            HorizontalAlignment="Center">

                    <!-- Nombre -->
                    <!-- Nombre -->
                    <!-- Nombre -->
                    <!-- Nombre -->
                    <TextBlock Text="Nombre"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"/>
                    <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RetroBox}"
                             Height="36"/>

                    <!-- Apellido -->
                    <TextBlock Text="Apellido"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               Margin="0,10,0,4"/>
                    <TextBox Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RetroBox}"
                             Height="39"/>

                    <!-- Nombre de usuario -->
                    <TextBlock Text="Nombre de Usuario"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               Margin="0,10,0,4"/>
                    <TextBox Text="{Binding Username}"
                             Style="{StaticResource RetroBox}"
                             Height="38"
                             IsReadOnly="True"/>

                    <!-- Correo -->
                    <TextBlock Text="Correo Electrónico"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               Margin="0,10,0,4"/>
                    <TextBox Text="{Binding Correo, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RetroBox}"
                             Height="41"/>

                    <!-- Fecha nacimiento -->
                    <TextBlock Text="Fecha de Nacimiento"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               Margin="0,10,0,4"/>
                    <DatePicker SelectedDate="{Binding Birthdate}"
                                FontFamily="{StaticResource PokemonClassic}"
                                Style="{StaticResource RetroBox}"
                                Height="42"/>

                    <!-- Contraseña -->
                    <TextBlock Text="Contraseña"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               Margin="0,10,0,4"/>
                    <PasswordBox x:Name="txtPass"
                                 Style="{StaticResource RetroBox}"
                                 Height="30"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <!-- Confirmar contraseña -->
                    <TextBlock Text="Confirmar Contraseña"
                               FontFamily="{StaticResource PokemonClassic}"
                               Style="{StaticResource RetroText}"
                               Margin="0,10,0,4"/>
                    <PasswordBox x:Name="txtPassConfirm"
                                 Style="{StaticResource RetroBox}"
                                 Height="30"
                                 PasswordChanged="PasswordBoxConfirm_PasswordChanged"/>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">

                        <Button Content="Guardar"
                                FontFamily="{StaticResource PokemonClassic}"
                                Width="128"
                                Style="{StaticResource RetroButton}"
                                Margin="0,0,20,0"
                                Command="{Binding GuardarCommand}" RenderTransformOrigin="0.387,-0.386"/>

                        <Button Content="Cancelar"
                                FontFamily="{StaticResource PokemonClassic}"
                                Width="129"
                                Style="{StaticResource RetroButton}"
                                Command="{Binding CancelarCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
