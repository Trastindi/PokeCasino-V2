<Window x:Class="PK_Proyect.View.PokedexView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pokédex"
        Height="900" Width="460"
        MinHeight="900" MinWidth="460"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BgTop"     Color="#CA215A"/>
        <SolidColorBrush x:Key="BgBottom"  Color="#FE1A55"/>
        <SolidColorBrush x:Key="DPadColor" Color="#001A4D"/>
        <SolidColorBrush x:Key="White"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextDark"  Color="#212121"/>

        <!-- Botón teclado numérico -->
        <Style x:Key="KeyBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2AA8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#001A4D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="{StaticResource PokemonClassic}"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="48"/>
        </Style>

        <!-- Botón acción SEARCH / CLEAR -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#001A4D"/>
            <Setter Property="BorderBrush"     Value="#001A4D"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontFamily"      Value="{StaticResource PokemonClassic}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <!-- D-Pad: Button transparente dentro de Border con CornerRadius -->
        <Style x:Key="DPadBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="44"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Contenedor principal -->
    <Border CornerRadius="14" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Barra título -->
                <RowDefinition Height="40"/>
                <!-- Panel superior (cámara + pantalla + D-Pad) -->
                <RowDefinition Height="*"/>
                <!-- Panel inferior (teclado + tipos + acciones) -->
                <RowDefinition Height="420"/>
            </Grid.RowDefinitions>

            <!-- ════════════ BARRA TÍTULO ════════════ -->
            <Border Grid.Row="0" Background="#001A4D" CornerRadius="14,14,0,0">
                <Grid>
                    <TextBlock Text="POKÉDEX"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Border HorizontalAlignment="Right" Margin="0,0,10,0"
                            Width="26" Height="26" CornerRadius="5"
                            Background="#E00000">
                        <Button Foreground="White" Background="Transparent"
                                BorderThickness="0" FontWeight="Bold"
                                Click="btnClose_Click" Cursor="Hand"
                                Width="26" Height="26">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </ControlTemplate>
                            </Button.Template>
                            X
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════════ PANEL SUPERIOR ════════════ -->
            <Border Grid.Row="1" Background="#CA215A">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Cámara + lámparas -->
                        <RowDefinition Height="72"/>
                        <!-- Pantalla central -->
                        <RowDefinition Height="*"/>
                        <!-- D-Pad -->
                        <RowDefinition Height="90"/>
                    </Grid.RowDefinitions>

                    <!-- Lámparas -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="18,0,0,0">
                        <Ellipse Width="52" Height="52" Fill="White"
                                 Stroke="#001A4D" StrokeThickness="3" Margin="0,0,10,0"/>
                        <Ellipse Width="18" Height="18" Fill="#FF0000"
                                 Stroke="#001A4D" StrokeThickness="2" Margin="0,0,5,0"/>
                        <Ellipse Width="18" Height="18" Fill="#FFCC00"
                                 Stroke="#001A4D" StrokeThickness="2" Margin="0,0,5,0"/>
                        <Ellipse Width="18" Height="18" Fill="#33CC33"
                                 Stroke="#001A4D" StrokeThickness="2"/>
                    </StackPanel>

                    <!-- Pantalla central -->
                    <Border Grid.Row="1" Background="#1A0010"
                            Margin="18,6,18,6" CornerRadius="8">
                        <Grid>
                            <!-- MODO SPRITE -->
                            <Image x:Name="imgSprite"
                                   Source="{Binding CurrentSprite}"
                                   Width="160" Height="160"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding SpritePanelVisible}"/>

                            <!-- MODO DESCRIPCIÓN -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding DescripcionPanelVisible}"
                                          Margin="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding NombreDisplay}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#FFD700"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,8"/>
                                    <TextBlock Text="{Binding Descripcion}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="12" Foreground="#E0E0E0"
                                               TextWrapping="Wrap" Margin="6,0,6,6"/>
                                    <ItemsControl ItemsSource="{Binding Stats}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="6,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="36"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Nombre}"
                                                               FontFamily="{StaticResource PokemonClassic}"
                                                               FontSize="11" Foreground="#AAA"/>
                                                    <ProgressBar Grid.Column="1" Value="{Binding Valor}"
                                                                 Maximum="255" Height="12"
                                                                 Background="#333" Foreground="#4CAF50"
                                                                 VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Valor}"
                                                               FontFamily="{StaticResource PokemonClassic}"
                                                               FontSize="11" Foreground="White"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- MODO REGIÓN -->
                            <StackPanel Visibility="{Binding RegionPanelVisible}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="REGIÓN"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="12" Foreground="#AAA"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Region}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#FFD700"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                                <TextBlock Text="{Binding NumeroDisplay}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="15" Foreground="White"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- D-PAD -->
                    <Grid Grid.Row="2" HorizontalAlignment="Right" Margin="0,0,24,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="44"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="1"
                                Background="#001A4D" CornerRadius="10,10,0,0">
                            <Button Style="{StaticResource DPadBtn}" Content="▲"
                                    Command="{Binding ClickUpCommand}"/>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0"
                                Background="#001A4D" CornerRadius="10,0,0,10">
                            <Button Style="{StaticResource DPadBtn}" Content="◄"
                                    Command="{Binding ClickLeftCommand}"/>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Background="#001A4D"/>

                        <Border Grid.Row="1" Grid.Column="2"
                                Background="#001A4D" CornerRadius="0,10,10,0">
                            <Button Style="{StaticResource DPadBtn}" Content="►"
                                    Command="{Binding ClickRightCommand}"/>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="1"
                                Background="#001A4D" CornerRadius="0,0,10,10">
                            <Button Style="{StaticResource DPadBtn}" Content="▼"
                                    Command="{Binding ClickDownCommand}"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ════════════ PANEL INFERIOR ════════════ -->
            <Border Grid.Row="2" Background="#FE1A55" CornerRadius="0,0,14,14">
                <Grid Margin="14,10,14,10">
                    <Grid.RowDefinitions>
                        <!-- Display número -->
                        <RowDefinition Height="52"/>
                        <!-- Separador -->
                        <RowDefinition Height="8"/>
                        <!-- Teclado numérico -->
                        <RowDefinition Height="Auto"/>
                        <!-- Separador -->
                        <RowDefinition Height="10"/>
                        <!-- Tipos -->
                        <RowDefinition Height="52"/>
                        <!-- Separador -->
                        <RowDefinition Height="8"/>
                        <!-- SEARCH / CLEAR -->
                        <RowDefinition Height="56"/>
                    </Grid.RowDefinitions>

                    <!-- Display número -->
                    <Border Grid.Row="0" Background="#1A0010" CornerRadius="6">
                        <TextBlock Text="{Binding InputPokedexNo}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="22" Foreground="#E9E9E9"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Teclado 2 filas -->
                    <StackPanel Grid.Row="2">
                        <UniformGrid Rows="1" Columns="5">
                            <Button Content="0" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="0"/>
                            <Button Content="1" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="1"/>
                            <Button Content="2" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="2"/>
                            <Button Content="3" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="3"/>
                            <Button Content="4" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="4"/>
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="5" Margin="0,3,0,0">
                            <Button Content="5" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="5"/>
                            <Button Content="6" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="6"/>
                            <Button Content="7" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="7"/>
                            <Button Content="8" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="8"/>
                            <Button Content="9" Style="{StaticResource KeyBtn}" Command="{Binding KeypadCommand}" CommandParameter="9"/>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Tipos -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border CornerRadius="5" Padding="16,8" Margin="5,0"
                                Background="{Binding Tipo1Background}">
                            <TextBlock Text="{Binding Tipo1}"
                                       FontFamily="{StaticResource PokemonClassic}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{Binding Tipo1Foreground}"
                                       Visibility="{Binding Tipo1Visible}"/>
                        </Border>
                        <Border CornerRadius="5" Padding="16,8" Margin="5,0"
                                Background="{Binding Tipo2Background}"
                                Visibility="{Binding Tipo2Visible}">
                            <TextBlock Text="{Binding Tipo2}"
                                       FontFamily="{StaticResource PokemonClassic}"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="{Binding Tipo2Foreground}"/>
                        </Border>
                    </StackPanel>

                    <!-- SEARCH / CLEAR -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="SEARCH" Style="{StaticResource ActionBtn}"
                                Margin="0,0,5,0" Command="{Binding SearchCommand}"/>
                        <Button Grid.Column="1" Content="CLEAR"  Style="{StaticResource ActionBtn}"
                                Margin="5,0,5,0" Command="{Binding ClearCommand}"/>
                        <Ellipse Grid.Column="2" Width="38" Height="38"
                                 Fill="#FFCC00" Stroke="#001A4D" StrokeThickness="2"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
