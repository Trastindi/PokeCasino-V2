<Window x:Class="PK_Proyect.Views.DetallePokemonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle Pokémon"
        Width="440" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Estilo fila de estadística -->
        <Style x:Key="StatRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="#1a1a2e"
            BorderBrush="#e94560"
            BorderThickness="2"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="#16213e" Height="44">
                <TextBlock Text="Detalle Pokémon"
                           Foreground="#e94560"
                           FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontFamily="Courier New"/>
                <Button Content="✕"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Width="28" Height="28"
                        Background="Transparent"
                        Foreground="#e94560"
                        BorderBrush="Transparent"
                        FontWeight="Bold" FontSize="14"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16">
                <StackPanel>

                    <!-- Sprite + Número -->
                    <Grid HorizontalAlignment="Center" Margin="0,8,0,4">
                        <Border Width="120" Height="120"
                                Background="#16213e"
                                CornerRadius="60"
                                BorderBrush="#e94560"
                                BorderThickness="2">
                            <Image Source="{Binding SpriteUrl}"
                                   Width="96" Height="96"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Nombre + Número -->
                    <TextBlock Text="{Binding Nombre}"
                               Foreground="White"
                               FontSize="20" FontWeight="Bold"
                               FontFamily="Courier New"
                               HorizontalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Center" Margin="0,2,0,12">
                        <Run Text="#" Foreground="#aaa" FontFamily="Courier New"/>
                        <Run Text="{Binding NumeroPokedex}" Foreground="#aaa" FontFamily="Courier New"/>
                    </TextBlock>

                    <!-- Separador -->
                    <Separator Background="#e94560" Margin="0,0,0,10"/>

                    <!-- Info general -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nivel" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Nivel}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Tipo" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding TipoPrincipal}" Foreground="#4fc3f7" FontFamily="Courier New" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text=" / " Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                            <TextBlock Text="{Binding TipoSecundario}" Foreground="#4fc3f7" FontFamily="Courier New" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Habilidad" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Habilidad}" Foreground="White" FontFamily="Courier New" FontSize="12"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Objeto" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Objeto}" Foreground="White" FontFamily="Courier New" FontSize="12"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Obtenido" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FechaObtenido}" Foreground="White" FontFamily="Courier New" FontSize="12"/>
                    </Grid>

                    <!-- Separador -->
                    <Separator Background="#333" Margin="0,0,0,10"/>

                    <!-- Estadísticas -->
                    <TextBlock Text="ESTADÍSTICAS" Foreground="#e94560"
                               FontFamily="Courier New" FontSize="12" FontWeight="Bold"
                               Margin="0,0,0,6"/>

                    <!-- PS -->
                    <Grid Style="{StaticResource StatRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PS" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatPs}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold" Width="32"/>
                            <ProgressBar Value="{Binding StatPs}" Maximum="255" Width="120" Height="8"
                                         Foreground="#e94560" Background="#333" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Ataque -->
                    <Grid Style="{StaticResource StatRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ataque" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatAtaque}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold" Width="32"/>
                            <ProgressBar Value="{Binding StatAtaque}" Maximum="255" Width="120" Height="8"
                                         Foreground="#f4a261" Background="#333" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Defensa -->
                    <Grid Style="{StaticResource StatRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Defensa" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatDefensa}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold" Width="32"/>
                            <ProgressBar Value="{Binding StatDefensa}" Maximum="255" Width="120" Height="8"
                                         Foreground="#4fc3f7" Background="#333" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Ataque Especial -->
                    <Grid Style="{StaticResource StatRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ataque Esp." Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatAtaqueEspecial}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold" Width="32"/>
                            <ProgressBar Value="{Binding StatAtaqueEspecial}" Maximum="255" Width="120" Height="8"
                                         Foreground="#c77dff" Background="#333" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Defensa Especial -->
                    <Grid Style="{StaticResource StatRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Defensa Esp." Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatDefensaEspecial}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold" Width="32"/>
                            <ProgressBar Value="{Binding StatDefensaEspecial}" Maximum="255" Width="120" Height="8"
                                         Foreground="#90e0ef" Background="#333" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Velocidad -->
                    <Grid Style="{StaticResource StatRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Velocidad" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding StatVelocidad}" Foreground="White" FontFamily="Courier New" FontSize="12" FontWeight="Bold" Width="32"/>
                            <ProgressBar Value="{Binding StatVelocidad}" Maximum="255" Width="120" Height="8"
                                         Foreground="#b7e4c7" Background="#333" BorderThickness="0"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Separador -->
                    <Separator Background="#333" Margin="0,10,0,10"/>

                    <!-- Movimientos -->
                    <TextBlock Text="MOVIMIENTOS" Foreground="#e94560"
                               FontFamily="Courier New" FontSize="12" FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <ItemsControl ItemsSource="{Binding Movimientos}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#16213e"
                                        BorderBrush="#e94560"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        Margin="0,0,6,6">
                                    <TextBlock Text="{Binding}" Foreground="White"
                                               FontFamily="Courier New" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="#333" Margin="0,10,0,10"/>

                    <!-- HP actual -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="HP actual" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding CurrentHp}" Foreground="#b7e4c7" FontFamily="Courier New" FontSize="12" FontWeight="Bold"/>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Estado" Foreground="#aaa" FontFamily="Courier New" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="#f4a261" FontFamily="Courier New" FontSize="12"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
