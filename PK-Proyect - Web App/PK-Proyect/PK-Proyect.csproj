      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Resource>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Fonts\PokemonClassic.ttf">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Resource>
