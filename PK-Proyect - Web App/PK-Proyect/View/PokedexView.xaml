<Window x:Class="PK_Proyect.View.PokedexView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pokedex"
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="20">
            <TextBlock Text="Pokedex"
                       FontSize="28"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Black"/>
        </Grid>
    </Border>
</Window>
