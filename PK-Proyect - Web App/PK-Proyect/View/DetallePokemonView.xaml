<Window x:Class="PK_Proyect.View.DetallePokemonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle Pokémon"
        Height="580" Width="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue"   Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed"    Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox"    Color="#FFF5F2DF"/>
    </Window.Resources>

    <Border CornerRadius="18" BorderThickness="3" BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/PokeYellow2.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="15" BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Barra superior -->
                <Border Grid.Row="0" Background="{StaticResource PkYellow}"
                        CornerRadius="15,15,0,0">
                    <Grid>
                        <TextBlock Text="{Binding Nombre}"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource PkBlue}"/>
                        <Button Content="X"
                                FontFamily="{StaticResource PokemonClassic}"
                                FontSize="18"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                HorizontalAlignment="Right" Margin="0,4,8,4"
                                Click="btnClose_Click"/>
                    </Grid>
                </Border>

                <!-- Contenido -->
                <ScrollViewer Grid.Row="1" Margin="12,10,12,10"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Sprite centrado -->
                        <Image Source="{Binding Sprite}"
                               Width="120" Height="120"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                        <!-- Nº Pokédex + Nombre -->
                        <TextBlock FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="13" HorizontalAlignment="Center"
                                   Foreground="#555"
                                   Margin="0,0,0,2">
                            <Run Text="#"/><Run Text="{Binding NumeroPokedex}"/>
                        </TextBlock>

                        <!-- Separador -->
                        <Separator Margin="0,6,0,6" Background="#BBAA88"/>

                        <!-- Info básica -->
                        <StackPanel Margin="4,0">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Nivel: "
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding Nivel}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" Foreground="Black"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Tipo: "
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding TipoPrincipal}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" Foreground="Black"/>
                                <TextBlock Text="{Binding TipoSecundario, StringFormat=' / {0}'}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" Foreground="#555"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Habilidad: "
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding AbilityId}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" Foreground="Black"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Objeto: "
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding ItemId, TargetNullValue='Ninguno'}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" Foreground="Black"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Obtenido: "
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding FechaObtenido, StringFormat='{}{0:dd/MM/yyyy}'}"
                                           FontFamily="{StaticResource PokemonClassic}"
                                           FontSize="13" Foreground="Black"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Separador -->
                        <Separator Margin="0,8,0,6" Background="#BBAA88"/>

                        <!-- Estadísticas -->
                        <TextBlock Text="ESTADÍSTICAS"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource PkBlue}"
                                   Margin="0,0,0,6"/>

                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PS"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" Foreground="#333"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EstadisticasBase.Ps}"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" FontWeight="Bold" Foreground="Black"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ataque"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" Foreground="#333"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EstadisticasBase.Ataque}"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" FontWeight="Bold" Foreground="Black"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Defensa"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" Foreground="#333"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EstadisticasBase.Defensa}"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" FontWeight="Bold" Foreground="Black"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Atk. Esp."
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" Foreground="#333"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EstadisticasBase.AtaqueEspecial}"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" FontWeight="Bold" Foreground="Black"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Def. Esp."
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" Foreground="#333"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EstadisticasBase.DefensaEspecial}"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" FontWeight="Bold" Foreground="Black"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Velocidad"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" Foreground="#333"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding EstadisticasBase.Velocidad}"
                                       FontFamily="{StaticResource PokemonClassic}" FontSize="12" FontWeight="Bold" Foreground="Black"/>
                        </Grid>

                        <!-- Separador -->
                        <Separator Margin="0,8,0,6" Background="#BBAA88"/>

                        <!-- Movimientos -->
                        <TextBlock Text="MOVIMIENTOS"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource PkBlue}"
                                   Margin="0,0,0,4"/>

                        <ItemsControl ItemsSource="{Binding MoveSet}" Margin="8,0,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#D0C090" BorderBrush="Black" BorderThickness="1"
                                            Padding="6,3" Margin="2"
                                            CornerRadius="3">
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{StaticResource PokemonClassic}"
                                                   FontSize="12" Foreground="Black"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>
    </Border>
</Window>
