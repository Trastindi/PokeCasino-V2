<Window x:Class="PK_Proyect.Views.ResultadosMultiView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resultados de la Multi"
        Height="485" Width="394"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <StackPanel Margin="10">

            <TextBlock Text="Resultados"
                       FontSize="22"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <ScrollViewer Height="300">
                <ItemsControl x:Name="ListaResultados">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black" BorderThickness="2" Margin="5" Padding="5" Background="#E0D0A8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Nombre}"
                                               FontSize="12"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontWeight="Bold"
                                               Width="150"/>
                                    <TextBlock Text="Nivel: " FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Nivel}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Content="Cerrar"
                    Width="100" Height="30"
                    FontFamily="{StaticResource PokemonClassic}"
                    HorizontalAlignment="Center"
                    Margin="0 10 0 0"
                    Background="#D8C090"
                    Click="Cerrar"/>
        </StackPanel>
    </Border>
</Window>
