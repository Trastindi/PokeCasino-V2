<Window x:Class="PK_Proyect.View.MisMensajesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mis Mensajes"
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Título -->
                <RowDefinition Height="*"/>      <!-- Lista scrollable -->
                <RowDefinition Height="Auto"/>   <!-- Botón aceptar desafío -->
            </Grid.RowDefinitions>

            <!-- TÍTULO RETRO -->
            <TextBlock Text="Mis Mensajes"
                       Grid.Row="0"
                       FontSize="26"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <!-- LISTA SCROLLABLE -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Mensajes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="5"
                                    Padding="8"
                                    Background="#E0D0A8"
                                    Cursor="Hand">

                                <!-- Seleccionar al hacer clic -->
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SeleccionarMensajeCommand,
                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <StackPanel Orientation="Vertical">

                                    <!-- REMITENTE -->
                                    <TextBlock Text="{Binding Remitente}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="Black"/>

                                    <!-- FECHA -->
                                    <TextBlock Text="{Binding Fecha, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="12"
                                               Foreground="#555"
                                               Margin="0 2 0 0"/>

                                    <!-- CONTENIDO -->
                                    <TextBlock Text="{Binding Contenido}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="Black"
                                               TextWrapping="Wrap"
                                               Margin="0 4 0 0"/>

                                    <!-- BADGE DESAFÍO (solo si hay TipoBatallaId) -->
                                    <TextBlock Text="⚔ Desafío de batalla"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="DarkRed"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Margin="0 4 0 0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TipoBatallaId}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <!-- Visible cuando TipoBatallaId tiene valor -->
                                                    <DataTrigger Binding="{Binding TipoBatallaId}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- LEÍDO -->
                                    <TextBlock Text="{Binding Leido, StringFormat='Leído: {0}'}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="Gray"
                                               FontSize="11"
                                               Margin="0 2 0 0"/>

                                </StackPanel>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>

            <!-- BOTÓN ACEPTAR DESAFÍO -->
            <Button Grid.Row="2"
                    Content="Aceptar Desafío"
                    Command="{Binding AceptarDesafioCommand}"
                    FontFamily="{StaticResource PokemonClassic}"
                    FontSize="14"
                    Margin="5 10 5 5"
                    Padding="10 6"
                    Background="#CC3333"
                    Foreground="White"
                    BorderBrush="Black"
                    BorderThickness="2"/>

        </Grid>
    </Border>
</Window>
