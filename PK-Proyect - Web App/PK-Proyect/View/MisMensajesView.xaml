<Window x:Class="PK_Proyect.View.MisMensajesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mis Mensajes"
        Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Título -->
                <RowDefinition Height="*"/>
                <!-- Lista scrollable -->
            </Grid.RowDefinitions>

            <!-- TÍTULO RETRO -->
            <TextBlock Text="Mis Mensajes"
                       Grid.Row="0"
                       FontSize="26"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <!-- LISTA SCROLL RETRO -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Mensajes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="5"
                                    Padding="5"
                                    Background="#E0D0A8">

                                <StackPanel Orientation="Vertical">

                                    <!-- REMITENTE -->
                                    <TextBlock Text="{Binding Remitente}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="Black"/>

                                    <!-- FECHA -->
                                    <TextBlock Text="{Binding Fecha, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="Black"/>

                                    <!-- CONTENIDO -->
                                    <TextBlock Text="{Binding Contenido}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="Black"
                                               TextWrapping="Wrap"
                                               Margin="0 4 0 0"/>

                                    <!-- LEÍDO -->
                                    <TextBlock Text="{Binding Leido, StringFormat='Leído: {0}'}"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               Foreground="Gray"
                                               FontSize="12"
                                               Margin="0 2 0 0"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>

        </Grid>
    </Border>
</Window>
