<Window x:Class="PK_Proyect.Views.HistoricoTiradasView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial de Tiradas"
        Height="585" Width="502"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <StackPanel Margin="10">

            <!-- TÍTULO -->
            <TextBlock x:Name="Historico" Text="Historial de Tiradas"
                       FontSize="22"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <!-- LISTA DE TIRADAS -->
            <ScrollViewer Height="360">
                <ItemsControl ItemsSource="{Binding Tiradas}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="5"
                                    Padding="5"
                                    Background="#E0D0A8">

                                <StackPanel>

                                    <TextBlock Text="{Binding NombrePokemon}"
                                               FontSize="14"
                                               FontFamily="{StaticResource PokemonClassic}"
                                               FontWeight="Bold"
                                               Foreground="Black"/>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Zona: "
                                                   FontWeight="Bold"
                                                   Foreground="Black"/>
                                        <TextBlock Text="{Binding Zona}" Foreground="Black"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Tipo: "
                                                   FontWeight="Bold"
                                                   Foreground="Black"/>
                                        <TextBlock Text="{Binding TipoTirada}" Foreground="Black"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Fecha: "
                                                   FontWeight="Bold"
                                                   Foreground="Black"/>
                                        <TextBlock Text="{Binding FechaDisplay}" Foreground="Black"/>
                                    </StackPanel>

                                </StackPanel>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- BOTÓN CERRAR -->
            <Button Content="Cerrar"
                    Width="100" Height="30"
                    FontFamily="{StaticResource PokemonClassic}"
                    HorizontalAlignment="Center"
                    Margin="0 10 0 0"
                    Background="#D8C090"
                    Click="Cerrar"/>
        </StackPanel>
    </Border>
</Window>
