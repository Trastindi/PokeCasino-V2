<Window x:Class="PK_Proyect.View.ChangePasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Contraseña"
        Width="575" Height="538"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="18"
            BorderThickness="3"
            BorderBrush="#FFD700">
        <Border.Background>
            <ImageBrush ImageSource="/Images/perfil.webp"
                        Stretch="UniformToFill"/>
            
        </Border.Background>

        <Border BorderBrush="#FFD700"
                BorderThickness="4"
                CornerRadius="15"
                Margin="20">

            

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <TextBlock Text="CAMBIAR CONTRASEÑA"
                           Grid.Row="0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFD700"
                           FontFamily="{StaticResource PokemonClassic}"/>

                <!-- CAMPOS -->
                <StackPanel Grid.Row="1" Margin="40,20,40,0">

                    <TextBlock Text="Contraseña actual:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                    <PasswordBox x:Name="TxtActual"
                                 PasswordChanged="TxtActual_PasswordChanged"
                                 Height="32"
                                 Background="#1A1A1A"
                                 Opacity="0.7"
                                 Foreground="White"
                                 BorderBrush="#FFD700"
                                 BorderThickness="3"
                                 Margin="0,5,0,20"/>

                    <TextBlock Text="Nueva contraseña:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                    <PasswordBox x:Name="TxtNueva"
                                 PasswordChanged="TxtNueva_PasswordChanged"
                                 Height="32"
                                 Opacity="0.7"
                                 Background="#1A1A1A"
                                 Foreground="White"
                                 BorderBrush="#FFD700"
                                 BorderThickness="3"
                                 Margin="0,5,0,20"/>

                    <TextBlock Text="Confirmar nueva contraseña:"
                               Foreground="#FFD700"
                               FontFamily="{StaticResource PokemonClassic}"
                               FontSize="16"/>
                    <PasswordBox x:Name="TxtConfirmar"
                                 PasswordChanged="TxtConfirmar_PasswordChanged"
                                 Height="32"
                                 Opacity="0.7"
                                 Background="#1A1A1A"
                                 Foreground="White"
                                 BorderBrush="#FFD700"
                                 BorderThickness="3"
                                 Margin="0,5,0,0"/>
                </StackPanel>

                <!-- BOTONES -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Button Content="CANCELAR"
                            Width="150"
                            Background="#FFD700"
                            Foreground="Black"
                            FontFamily="{StaticResource PokemonClassic}"
                            FontWeight="Bold"
                            FontSize="14"
                            Margin="10,0"
                            Click="BtnCancelar_Click"/>

                    <Button Content="CAMBIAR"
                            Width="150"
                            Background="#FFD700"
                            Foreground="Black"
                            FontFamily="{StaticResource PokemonClassic}"
                            FontWeight="Bold"
                            FontSize="14"
                            Margin="10,0"
                            Click="BtnCambiar_Click"/>

                </StackPanel>

            </Grid>
        </Border>
    </Border>
</Window>
