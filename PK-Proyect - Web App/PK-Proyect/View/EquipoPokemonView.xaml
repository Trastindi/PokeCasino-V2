<Window x:Class="PK_Proyect.View.EquipoPokemonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionar Equipos"
        Height="560" Width="480"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PkYellow" Color="#FFD733"/>
        <SolidColorBrush x:Key="PkBlue"   Color="#2A2AA8"/>
        <SolidColorBrush x:Key="PkRed"    Color="#E00000"/>
        <SolidColorBrush x:Key="PkWhite"  Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PkBox"    Color="#FFF5F2DF"/>

        <Style x:Key="RetroBtn" TargetType="Button">
            <Setter Property="FontFamily"       Value="{StaticResource PokemonClassic}"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="Foreground"       Value="{StaticResource PkWhite}"/>
            <Setter Property="Background"       Value="{StaticResource PkBlue}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource PkRed}"/>
            <Setter Property="BorderThickness"  Value="3"/>
            <Setter Property="Padding"          Value="8,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>

        <!-- Estilo para cada fila de equipo (clickable) -->
        <Style x:Key="EquipoItem" TargetType="Border">
            <Setter Property="Background"       Value="#E0D0A8"/>
            <Setter Property="BorderBrush"      Value="Black"/>
            <Setter Property="BorderThickness"  Value="2"/>
            <Setter Property="Margin"           Value="4,4,4,0"/>
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18" BorderThickness="3" BorderBrush="{StaticResource PkBlue}">
        <Border.Background>
            <ImageBrush ImageSource="/Images/PokeYellow2.webp" Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="15" BorderThickness="3"
                BorderBrush="{StaticResource PkBlue}"
                Background="{StaticResource PkBox}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>  <!-- barra superior -->
                    <RowDefinition Height="Auto"/> <!-- botón crear -->
                    <RowDefinition Height="*"/>    <!-- lista -->
                </Grid.RowDefinitions>

                <!-- ── Barra superior ── -->
                <Border Grid.Row="0" Background="{StaticResource PkYellow}"
                        CornerRadius="15,15,0,0">
                    <Grid>
                        <TextBlock Text="MIS EQUIPOS"
                                   FontFamily="{StaticResource PokemonClassic}"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{StaticResource PkBlue}"/>
                        <Button Content="X"
                                FontFamily="{StaticResource PokemonClassic}"
                                FontSize="18"
                                Background="{StaticResource PkRed}"
                                BorderBrush="{StaticResource PkBlue}"
                                HorizontalAlignment="Right" Margin="0,4,8,4"
                                Click="btnClose_Click"/>
                    </Grid>
                </Border>

                <!-- ── Botón Crear Equipo ── -->
                <Button Grid.Row="1"
                        Content="+ Crear Equipo"
                        Style="{StaticResource RetroBtn}"
                        Command="{Binding CrearEquipoCommand}"
                        Margin="12,10,12,4"
                        HorizontalAlignment="Stretch"/>

                <!-- ── Lista de equipos ── -->
                <ScrollViewer Grid.Row="2" Margin="8,4,8,10"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Equipos}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource EquipoItem}">
                                    <!-- Abrir detalle al pulsar -->
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                            Command="{Binding DataContext.VerDetalleCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    </Border.InputBindings>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontFamily="{StaticResource PokemonClassic}"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="Black"/>
                                            <TextBlock FontFamily="{StaticResource PokemonClassic}"
                                                       FontSize="11" Foreground="#555555">
                                                <Run Text="{Binding Integrantes.Count, StringFormat='({0} Pokémon)'}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Flecha indicadora -->
                                        <TextBlock Grid.Column="1"
                                                   Text="▶"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource PkBlue}"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <!-- Empty state -->
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Equipos.Count}" Value="0">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Margin="0,40,0,0">
                                                        <TextBlock Text="No tienes equipos aún."
                                                                   FontFamily="{StaticResource PokemonClassic}"
                                                                   FontSize="13"
                                                                   Foreground="#888"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="¡Crea tu primer equipo!"
                                                                   FontFamily="{StaticResource PokemonClassic}"
                                                                   FontSize="11"
                                                                   Foreground="#AAA"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>
    </Border>
</Window>
