                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="2.85" ScaleY="2.85"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform X="69" Y="-102"/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <!-- ETIQUETA FLOTANTE -->
