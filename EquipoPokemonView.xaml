<Window x:Class="PK_Proyect.View.EquipoPokemonView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Equipo Pokémon"
        Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8F0D8">

    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">
        <Grid Margin="10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Título -->
                <RowDefinition Height="*"/>
                <!-- Lista scrollable -->
            </Grid.RowDefinitions>

            <!-- TÍTULO RETRO -->
            <TextBlock Text="Equipo Pokémon"
                       Grid.Row="0"
                       FontSize="26"
                       FontFamily="{StaticResource PokemonClassic}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 15"
                       Foreground="Black"/>

            <!-- LISTA SCROLL RETRO -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Equipo}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Border BorderBrush="Black"
                                    BorderThickness="2"
                                    Margin="5"
                                    Padding="5"
                                    Background="#E0D0A8">

                                <StackPanel Orientation="Horizontal">

                                    <!-- SPRITE -->
                                    <Image Source="{Binding Sprite}"
                                           Width="64" Height="64"
                                           Margin="0 0 10 0"/>

                                    <!-- INFO -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Nombre}"
                                                   FontFamily="{StaticResource PokemonClassic}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="Black"/>

                                        <TextBlock Text="{Binding Nivel, StringFormat='Nivel: {0}'}"
                                                   FontFamily="{StaticResource PokemonClassic}"
                                                   Foreground="Black"/>

                                        
                                    </StackPanel>

                                </StackPanel>

                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </ScrollViewer>

        </Grid>
    </Border>
</Window>
