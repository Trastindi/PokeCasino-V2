<Window x:Class="PK_Proyect.View.SearchBattleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Batalla"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Padding="16"
        Background="{Binding BackgroundBrush}"
        FontFamily="{StaticResource PokemonClassic}" Height="206" Width="334">
    <Border BorderBrush="Black" BorderThickness="3" Margin="10" Background="#F8F0D8">


        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <TextBlock Grid.Row="0" Text="Buscar Batalla" FontSize="18" FontWeight="Bold" FontFamily="{StaticResource PokemonClassic}"
               HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <!-- Desafiar -->
            <Grid Grid.Row="1" Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
              Width="120"
              Height="{Binding ButtonHeight}"
              Background="{Binding ButtonBackground}"
              Foreground="{Binding ButtonForeground}"
              Content="Desafiar"
              Command="{Binding DesafiarCommand}"
              FontFamily="{StaticResource PokemonClassic}"
              Margin="0,0,6,0"/>
                <TextBox Grid.Column="2"
               Height="{Binding InputHeight}"
               VerticalAlignment="Center"
                     FontFamily="{StaticResource PokemonClassic}"
               Text="{Binding IdUserToChallenge, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="Introduce id_user a desafiar" Margin="2,0,0,0"/>
            </Grid>

            <!-- Unirse -->
            <Grid Grid.Row="2" Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
              Height="{Binding ButtonHeight}"
              Background="{Binding ButtonBackground}"
              Foreground="{Binding ButtonForeground}"
              Content="Unirse"
              Command="{Binding UnirseCommand}"
              FontFamily="{StaticResource PokemonClassic}" Grid.ColumnSpan="3" HorizontalAlignment="Left" Width="119"/>
                <TextBox Grid.Column="2"
               Height="18"
               VerticalAlignment="Center"
                     FontFamily="{StaticResource PokemonClassic}"
               Text="{Binding IdBattleToJoin, UpdateSourceTrigger=PropertyChanged}"
               ToolTip="Introduce id_battle a unirse" Margin="47,0,0,0"/>
            </Grid>

            <!-- Botón cancelar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,58,130,-56" Width="109"/>
            <Button
            Height="{Binding ButtonHeight}"
            Background="{Binding ButtonBackground}"
            Foreground="{Binding ButtonForeground}"
            Content="Cancelar"
            Command="{Binding CancelCommand}"
            FontFamily="{StaticResource PokemonClassic}" Margin="86,41,111,-40" Grid.Row="2"/>
        </Grid>
    </Border>
</Window>
